# MarketMySTR MCP Server Configuration

# GoHighLevel Private Integration Token
# Format: pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Get this from: MarketMySTR account settings > Integrations
GHL_PIT_TOKEN=pit-your-token-here

# GHL Location ID
# Get this from: MarketMySTR account settings > Business Info
GHL_LOCATION_ID=your-location-id-here

# MCP Authentication Token (shared secret)
# Used by Claude to authenticate requests to this server
# Generate a random secure string (e.g., 32 random characters)
# Example: use `node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"`
MCP_AUTH_TOKEN=your-random-secure-token-here

# Server port (default 3000)
# On Render, this is typically 3000. Render sets this automatically.
PORT=3000
